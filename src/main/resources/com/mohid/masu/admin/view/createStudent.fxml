<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mohid.masu.admin.controller.CreateStudentController"
            stylesheets="@../assets/styles.css"
            styleClass="dashboard-bg">

    <left>
        <VBox prefWidth="240.0" spacing="18.0" styleClass="sidebar">
            <padding>
                <Insets top="30" right="20" bottom="30" left="20"/>
            </padding>

            <children>
                <Label text="MASU Admin" styleClass="sidebar-title"/>
                <Label text="Create Student" styleClass="sidebar-subtitle"/>

                <VBox VBox.vgrow="ALWAYS"/>

                <Button text="Back to Dashboard"
                        onAction="#goBack"
                        maxWidth="1.7976931348623157E308"
                        styleClass="logout-btn"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="22.0" styleClass="dashboard-content" fillWidth="true">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <children>
                <VBox spacing="8.0">
                    <children>
                        <Label text="Create Student Account" styleClass="page-title"/>
                        <Label text="Add a new student with login credentials and profile information."
                               styleClass="page-subtitle"/>
                    </children>
                </VBox>

                <VBox spacing="18.0"
                      maxWidth="560.0"
                      styleClass="content-card">
                    <padding>
                        <Insets top="28" right="28" bottom="28" left="28"/>
                    </padding>

                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Full Name" styleClass="field-label"/>
                                <TextField fx:id="fullNameField"
                                           promptText="Enter full name"
                                           maxWidth="1.7976931348623157E308"
                                           styleClass="modern-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Username" styleClass="field-label"/>
                                <TextField fx:id="usernameField"
                                           promptText="Enter username"
                                           maxWidth="1.7976931348623157E308"
                                           styleClass="modern-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Password" styleClass="field-label"/>
                                <PasswordField fx:id="passwordField"
                                               promptText="Enter password"
                                               maxWidth="1.7976931348623157E308"
                                               styleClass="modern-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Gender" styleClass="field-label"/>
                                <ComboBox fx:id="genderComboBox"
                                          promptText="Select gender"
                                          maxWidth="1.7976931348623157E308"
                                          styleClass="modern-combo"/>
                            </children>
                        </VBox>

                        <HBox spacing="14.0">
                            <children>
                                <Button text="Create Student"
                                        onAction="#handleCreateStudent"
                                        prefWidth="170.0"
                                        prefHeight="46.0"
                                        styleClass="primary-btn"/>

                                <Button text="Clear"
                                        onAction="#handleClear"
                                        prefWidth="120.0"
                                        prefHeight="46.0"
                                        styleClass="secondary-btn"/>
                            </children>
                        </HBox>

                        <Label fx:id="messageLabel"
                               wrapText="true"
                               styleClass="error-label"/>
                    </children>
                </VBox>

                <VBox VBox.vgrow="ALWAYS"/>
            </children>
        </VBox>
    </center>
</BorderPane>