<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mohid.masu.admin.controller.DashboardController"
            stylesheets="@../assets/styles.css"
            prefWidth="1000.0" prefHeight="650.0"
            styleClass="dashboard-bg">

    <left>
        <VBox prefWidth="240.0" spacing="18.0" styleClass="sidebar">
            <padding>
                <Insets top="30" right="20" bottom="30" left="20"/>
            </padding>

            <children>
                <Label text="MASU Admin" styleClass="sidebar-title"/>
                <Label text="Control Panel" styleClass="sidebar-subtitle"/>

                <VBox spacing="12.0" style="-fx-padding: 25 0 0 0;">
                    <children>
                        <Button text="Create Student"
                                onAction="#goToCreateStudent"
                                maxWidth="1.7976931348623157E308"
                                styleClass="sidebar-btn"/>

                        <Button text="Manage Students"
                                maxWidth="1.7976931348623157E308"
                                styleClass="sidebar-btn-disabled"/> <!-- Not Working for now -->

                        <Button text="Manage Events"
                                maxWidth="1.7976931348623157E308"
                                styleClass="sidebar-btn-disabled"/> <!-- Not Working for now -->
                    </children>
                </VBox>

                <VBox VBox.vgrow="ALWAYS"/>

                <Button text="Logout"
                        onAction="#logout"
                        maxWidth="1.7976931348623157E308"
                        styleClass="logout-btn"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="22.0" styleClass="dashboard-content">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <children>
                <VBox spacing="8.0">
                    <children>
                        <Label text="Admin Dashboard" styleClass="page-title"/>
                        <Label text="Welcome to the MASU Event Booking Administration Portal."
                               styleClass="page-subtitle"/>
                    </children>
                </VBox>

                <HBox spacing="40.0">
                    <children>
                        <StackPane prefWidth="220.0" prefHeight="130.0" styleClass="info-card white-card">
                            <children>
                                <VBox alignment="CENTER" spacing="8.0">
                                    <children>
                                        <Label text="Students" styleClass="info-card-title-dark"/>
                                        <Label text="Create and manage student accounts" styleClass="info-card-text-dark" wrapText="true"/>
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>

                        <StackPane prefWidth="220.0" prefHeight="130.0" styleClass="info-card white-card">
                            <children>
                                <VBox alignment="CENTER" spacing="8.0">
                                    <children>
                                        <Label text="Events" styleClass="info-card-title-dark"/>
                                        <Label text="Update event details and allocations" styleClass="info-card-text-dark" wrapText="true"/>
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>
                    </children>
                </HBox>

                <VBox spacing="16.0" styleClass="content-card">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <children>
                        <Label text="Quick Actions" styleClass="section-title"/>

                        <HBox spacing="16.0">
                            <children>
                                <Button text="Create Student"
                                        onAction="#goToCreateStudent"
                                        prefWidth="180.0"
                                        prefHeight="48.0"
                                        styleClass="primary-btn"/>

                                <Button text="Logout"
                                        onAction="#logout"
                                        prefWidth="140.0"
                                        prefHeight="48.0"
                                        styleClass="secondary-btn"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>