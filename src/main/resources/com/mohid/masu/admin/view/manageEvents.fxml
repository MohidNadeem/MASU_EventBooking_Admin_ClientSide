<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mohid.masu.admin.controller.ManageEventsController"
            stylesheets="@../assets/styles.css"
            prefWidth="1200.0" prefHeight="720.0"
            styleClass="dashboard-bg">

    <left>
        <VBox prefWidth="240.0" spacing="18.0" styleClass="sidebar">
            <padding>
                <Insets top="30" right="20" bottom="30" left="20"/>
            </padding>

            <children>
                <Label text="MASU Admin" styleClass="sidebar-title"/>
                <Label text="Manage Events" styleClass="sidebar-subtitle"/>

                <VBox VBox.vgrow="ALWAYS"/>

                <Button text="Back to Dashboard"
                        onAction="#goBack"
                        maxWidth="1.7976931348623157E308"
                        styleClass="logout-btn"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="dashboard-content">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <children>
                <VBox spacing="8.0">
                    <children>
                        <Label text="Manage Events" styleClass="page-title"/>
                        <Label text="View events and cancel selected events."
                               styleClass="page-subtitle"/>
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="content-card">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <TableView fx:id="eventsTable" prefHeight="470.0" styleClass="students-table">
                            <columns>
                                <TableColumn fx:id="titleColumn" text="Title" prefWidth="160.0"/>
                                <TableColumn fx:id="typeColumn" text="Type" prefWidth="90.0"/>
                                <TableColumn fx:id="dateColumn" text="Date" prefWidth="110.0"/>
                                <TableColumn fx:id="startTimeColumn" text="Start Time" prefWidth="90.0"/>
                                <TableColumn fx:id="endTimeColumn" text="End Time" prefWidth="90.0"/>
                                <TableColumn fx:id="venueColumn" text="Venue" prefWidth="160.0"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0"/>
                                <TableColumn fx:id="costColumn" text="Cost" prefWidth="80.0"/>
                                <TableColumn fx:id="participantsColumn" text="Participants" prefWidth="110.0"/>
                                <TableColumn fx:id="alumniSlotsColumn" text="Alumni Slots" prefWidth="110.0"/>
                            </columns>
                        </TableView>

                        <HBox spacing="14.0">
                            <children>
                                <Button text="Refresh"
                                        onAction="#loadEvents"
                                        prefWidth="130.0"
                                        prefHeight="42.0"
                                        styleClass="secondary-btn"/>

                                <Button text="Cancel Selected Event"
                                        onAction="#cancelSelectedEvent"
                                        prefWidth="200.0"
                                        prefHeight="42.0"
                                        styleClass="primary-btn"/>
                            </children>
                        </HBox>

                        <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>